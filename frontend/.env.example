# Frontend runtime config (Vercel / static hosting)
#
# If you deploy the frontend separately from the Docker reverse-proxy (nginx),
# set these to point to your public backend.
#
# Examples:
# VITE_API_BASE_URL=https://api.your-domain.com
# VITE_SOCKET_URL=https://api.your-domain.com
# VITE_SOCKET_PATH=/socket.io

# Base URL for REST API requests. Leave empty for same-origin (/api/*).
VITE_API_BASE_URL=

# Base URL for Socket.IO. Leave empty for same-origin (/socket.io).
VITE_SOCKET_URL=

# Optional Socket.IO path (default: /socket.io)
VITE_SOCKET_PATH=/socket.io
