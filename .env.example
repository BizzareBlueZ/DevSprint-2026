# Security Configuration - DO NOT COMMIT .env FILE
# Copy this file to .env and update with secure values

# ── JWT Configuration ────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secure-random-256-bit-secret-here-min-32-characters
JWT_EXPIRES_IN=24h

# ── Web Push VAPID Keys ──────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here

# ── RabbitMQ Erlang Cookie ───────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RABBITMQ_ERLANG_COOKIE=your-secure-random-erlang-cookie-here

# ── Database Configuration ───────────────────────────────────
POSTGRES_DB=cafeteria
POSTGRES_USER=admin
POSTGRES_PASSWORD=your-secure-db-password-here
DB_HOST=postgres
DB_PORT=5432

# ── Redis Configuration ──────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── RabbitMQ Configuration ───────────────────────────────────
RABBITMQ_USER=admin_user
RABBITMQ_PASSWORD=your-secure-rabbitmq-password-here
RABBITMQ_URL=amqp://admin_user:your-secure-rabbitmq-password-here@rabbitmq:5672

# ── PgAdmin Configuration ────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@iut-dhaka.edu
PGADMIN_DEFAULT_PASSWORD=your-secure-pgadmin-password-here
PGADMIN_CONFIG_SERVER_MODE=False
PGADMIN_CONFIG_MASTER_PASSWORD_REQUIRED=False

# ── Application Ports ───────────────────────────────────────
IDENTITY_PROVIDER_PORT=3001
ORDER_GATEWAY_PORT=3000
STOCK_SERVICE_PORT=3002
KITCHEN_QUEUE_PORT=3003
NOTIFICATION_HUB_PORT=3004

# ── Service URLs ────────────────────────────────────────────
STOCK_SERVICE_URL=http://stock-service:3002
NOTIFICATION_HUB_URL=http://notification-hub:3004

# ── HTTPS/SSL Configuration ─────────────────────────────────
# Set ENABLE_HTTPS=true in production to enforce HTTPS + HSTS.
# docker-entrypoint.sh will select nginx-ssl.conf.template automatically.
# The Dockerfile generates a self-signed cert at startup (for dev/staging).
# For production use Let's Encrypt: mount real certs and update paths below.
ENABLE_HTTPS=false
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# ── Security Headers ────────────────────────────────────────
# Enable security headers in production
ENABLE_SECURITY_HEADERS=true

# ── Seed Passwords (used only by identity-provider/Seed.js) ─
# These control the demo account passwords created during DB seeding.
# Set unique values here; never use these defaults in production.
SEED_STUDENT_PASSWORD=changeme-student
SEED_ADMIN_PASSWORD=changeme-admin
SEED_IUTCS_ADMIN_PASSWORD=changeme-iutcs
