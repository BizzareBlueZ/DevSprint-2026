# Security Configuration - DO NOT COMMIT .env FILE
# Copy this file to .env and update with secure values

# ── JWT Configuration ────────────────────────────────────────
JWT_SECRET=your-secure-random-256-bit-secret-here-min-32-characters
JWT_EXPIRES_IN=24h

# ── Database Configuration ───────────────────────────────────
POSTGRES_DB=cafeteria
POSTGRES_USER=admin
POSTGRES_PASSWORD=your-secure-db-password-here
DB_HOST=postgres
DB_PORT=5432

# ── Redis Configuration ──────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── RabbitMQ Configuration ───────────────────────────────────
RABBITMQ_USER=admin_user
RABBITMQ_PASSWORD=your-secure-rabbitmq-password-here
RABBITMQ_URL=amqp://admin_user:your-secure-rabbitmq-password-here@rabbitmq:5672

# ── PgAdmin Configuration ────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@iut-dhaka.edu
PGADMIN_DEFAULT_PASSWORD=your-secure-pgadmin-password-here
PGADMIN_CONFIG_SERVER_MODE=False
PGADMIN_CONFIG_MASTER_PASSWORD_REQUIRED=False

# ── Application Ports ───────────────────────────────────────
IDENTITY_PROVIDER_PORT=3001
ORDER_GATEWAY_PORT=3000
STOCK_SERVICE_PORT=3002
KITCHEN_QUEUE_PORT=3003
NOTIFICATION_HUB_PORT=3004

# ── Service URLs ────────────────────────────────────────────
STOCK_SERVICE_URL=http://stock-service:3002
NOTIFICATION_HUB_URL=http://notification-hub:3004

# ── HTTPS/SSL Configuration ─────────────────────────────────
# Set to 'true' for production to enforce HTTPS
ENABLE_HTTPS=false
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# ── Security Headers ────────────────────────────────────────
# Enable security headers in production
ENABLE_SECURITY_HEADERS=true
