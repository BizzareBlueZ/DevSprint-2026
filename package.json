{
  "name": "devsprint-2026",
  "version": "1.0.0",
  "private": true,
  "description": "IUT Cafeteria System - Monorepo",
  "scripts": {
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
