    "format:check": "prettier --check \"**/*.{js,jsx,json,md,yml,yaml}\""
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5"
  }
}
